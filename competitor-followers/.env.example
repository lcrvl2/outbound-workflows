# Apify API Token (for LinkedIn follower extraction)
# Get from: https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxx

# Apollo.io API Key (for company enrichment + contact search)
# Get from: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=xxx

# Note: ANTHROPIC_API_KEY not needed for v1 (list creation only, no email generation)
# Uncomment if building v2 with email generation:
# ANTHROPIC_API_KEY=sk-ant-xxx
